# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Vertex AI
VERTEX_ENDPOINT_ID=your-vertex-endpoint-id
VERTEX_LOCATION=us-central1

# Firestore
FIRESTORE_COLLECTION_CERTIFICATES=certificates
FIRESTORE_COLLECTION_DECISIONS=decisions

# BigQuery
BQ_DATASET=pof_ai
BQ_TABLE_DECISIONS=decisions
BQ_HISTORICAL_BATCH_SIZE=1000

# Cloud KMS — certificate signing
KMS_KEY_RING=pof-ai-keyring
KMS_KEY_CERT=cert-signing-key
KMS_KEY_LOG=log-signing-key
KMS_LOCATION=global

# Cloud Storage
GCS_BUCKET_EVIDENCE=pof-ai-evidence
GCS_BUCKET_LOG=pof-ai-log

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# API security
API_KEY=your-strong-random-api-key-here

# Certificate verification URL base
CERT_BASE_URL=https://verify.pof-ai.app/cert

# Audit log service URL
LOG_SERVICE_URL=https://pof-ai-log-xxxx-uc.a.run.app

# Fairness thresholds
BIAS_DIFFERENCE_THRESHOLD=0.1
DISPARATE_IMPACT_LOW=0.8
DISPARATE_IMPACT_HIGH=1.25
MIN_SUBGROUP_SAMPLES=30

# Adversarial engine
ADVERSARIAL_N_PROBES=10
ADVERSARIAL_TEMPERATURE=0.7
